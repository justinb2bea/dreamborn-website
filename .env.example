# dreamborn.ai — Environment Variables
# Copy to .env for local development. NEVER commit .env.
# Set all production values in Cloudflare Pages dashboard → Settings → Environment Variables.

# Supabase (dreamborn project)
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Claude API (Anthropic) — for Finn chat
CLAUDE_API_KEY=<anthropic-api-key>

# Apollo.io — contact enrichment
APOLLO_API_KEY=<apollo-api-key>

# Cal.com webhook secret (set in Cal.com dashboard)
CALCOM_WEBHOOK_SECRET=<calcom-webhook-secret>

# Cloudflare Pages deploy hook URL (generated in CF Pages dashboard)
# Trigger Eleventy rebuild when new content is published
PAGES_DEPLOY_HOOK_URL=https://api.cloudflare.com/client/v4/pages/webhooks/deploy_hooks/<hook-id>
