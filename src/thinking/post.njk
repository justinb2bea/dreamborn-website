---
layout: base.njk
register: forge
pagination:
  data: posts
  size: 1
  alias: post
permalink: "/thinking/{{ post.slug }}/"
eleventyComputed:
  title: "{{ post.title }}"
  description: "{{ post.excerpt }}"
  socialTitle: "{{ post.title }}"
  socialDescription: "{{ post.excerpt }}"
  image: "{{ post.social_image or site.socialImages.article }}"
  imageAlt: "{{ post.social_image_alt or 'Dreamborn Thinking article social card.' }}"
  type: "article"
  published: "{{ post.published_at }}"
  modified: "{{ post.updated_at or post.published_at }}"
  author: "{{ post.author or 'Dreamborn' }}"
  section: "{{ post.topic_label or 'Thinking' }}"
---

<main class="thinking-detail">
  {% set displayAuthor = post.author or 'Dreamborn' %}
  <div class="detail-shell">
    <article class="detail-article">
      <header class="detail-article__header">
        <div class="detail-badge">
          <span></span>
          {{ post.topic_label or 'Operating System' }}
        </div>

        <h1>
          {% if post.title_html %}
            {{ post.title_html | safe }}
          {% else %}
            {{ post.title }}
          {% endif %}
        </h1>

        {% if post.excerpt %}
        <p class="detail-dek">{{ post.excerpt }}</p>
        {% endif %}

        <div class="detail-byline">
          <div class="detail-author-mark" aria-hidden="true">
            {% if displayAuthor == 'Justin King' %}
              <img src="/img/authors/JustinKingProfile.jpeg" alt="">
            {% else %}
              {{ displayAuthor | first }}
            {% endif %}
          </div>
          <div>
            <strong>{{ displayAuthor }}</strong>
            <span>
              Dreamborn
              {% if post.published_at %} · {{ post.published_at | dateFormat }}{% endif %}
              {% if post.body_html %} · {{ post.body_html | readingTime }}{% endif %}
            </span>
          </div>
        </div>
      </header>

      <aside class="detail-proof-inline" aria-label="Live verification state">
        <div class="detail-proof-inline__top">
          <div>
            <span></span>
            <strong>{% if post.hcs_receipt %}HCS verified article{% else %}Verification pending{% endif %}</strong>
          </div>
          <code>{% if post.hcs_receipt %}{{ post.hcs_receipt.event_type }}{% else %}content.receipt: pending{% endif %}</code>
        </div>
        <div class="detail-proof-inline__metrics">
          <div>
            <span>HCS topic</span>
            <strong>{{ post.hcs_receipt.topic_id if post.hcs_receipt else 'pending' }}</strong>
          </div>
          <div>
            <span>sequence</span>
            <strong>{{ post.hcs_receipt.sequence_number if post.hcs_receipt else 'pending' }}</strong>
          </div>
          <div>
            <span>content hash</span>
            <strong>{{ post.hcs_receipt.body_sha256 | truncate(18, true, '') if post.hcs_receipt else 'pending' }}</strong>
          </div>
          <div>
            <span>consensus</span>
            <strong>{{ post.hcs_receipt.consensus_timestamp | dateFormat if post.hcs_receipt else 'pending' }}</strong>
          </div>
        </div>
        {% if post.hcs_receipt %}
          <pre><code>hcs.verify("{{ post.slug }}") =&gt; PASSED [{{ post.hcs_receipt.transaction_id }}]</code></pre>
          <a class="detail-proof-inline__link" href="{{ post.hcs_receipt.hashscan_url }}" target="_blank" rel="noopener">Open HashScan receipt</a>
        {% else %}
          <pre><code>hcs.verify("{{ post.slug }}") =&gt; PENDING [receipt not published]</code></pre>
        {% endif %}
      </aside>

      <div class="detail-body">
        {% if post.body_html %}
          {{ post.body_html | safe }}
        {% elif post.body_md %}
          {{ post.body_md | safe }}
        {% else %}
          <p class="text-muted">Content coming soon.</p>
        {% endif %}
      </div>
    </article>

    <aside class="detail-rail" aria-label="Article context">
      <section>
        <h2>The author</h2>
        <p>
          {{ displayAuthor }} writes from inside Dreamborn&rsquo;s operating system: the company,
          the agents, the receipts, and the work moving through it.
        </p>
      </section>

      <section>
        <h2>Latest thinking</h2>
        <ul>
          {% for related in posts %}
          {% if loop.index <= 3 %}
          <li>
            <a href="/thinking/{{ related.slug }}/">
              <span>{{ related.topic_label or 'Article' }}</span>
              <strong>{{ related.title }}</strong>
            </a>
          </li>
          {% endif %}
          {% endfor %}
        </ul>
      </section>

      <section class="detail-network-proof">
        <h2>Network proof</h2>
        <dl>
          <div><dt>system</dt><dd>live</dd></div>
          <div><dt>receipts</dt><dd>recorded</dd></div>
          <div><dt>agents</dt><dd>active</dd></div>
        </dl>
        <a href="/live/">Watch the work move</a>
      </section>
    </aside>
  </div>

</main>
