---
layout: base.njk
register: forge
pagination:
  data: posts
  size: 1
  alias: post
permalink: "/thinking/{{ post.slug }}/"
eleventyComputed:
  title: "{{ post.title }} — Dreamborn"
---

<main class="thinking-detail">
  <div class="detail-shell">
    <article class="detail-article">
      <header class="detail-article__header">
        <div class="detail-badge">
          <span></span>
          {{ post.topic_label or 'Operating System' }}
        </div>

        <h1>
          {% if post.title_html %}
            {{ post.title_html | safe }}
          {% else %}
            {{ post.title }}
          {% endif %}
        </h1>

        {% if post.excerpt %}
        <p class="detail-dek">{{ post.excerpt }}</p>
        {% endif %}

        <div class="detail-byline">
          <div class="detail-author-mark" aria-hidden="true">
            {% if post.author == 'Justin King' %}
              <img src="/img/authors/JustinKingProfile.jpeg" alt="">
            {% else %}
              {{ post.author | first }}
            {% endif %}
          </div>
          <div>
            <strong>{{ post.author }}</strong>
            <span>
              Dreamborn
              {% if post.published_at %} · {{ post.published_at | dateFormat }}{% endif %}
              {% if post.body_html %} · {{ post.body_html | readingTime }}{% endif %}
            </span>
          </div>
        </div>
      </header>

      <aside class="detail-proof-inline" aria-label="Live verification state">
        <div class="detail-proof-inline__top">
          <div>
            <span></span>
            <strong>Live verification state</strong>
          </div>
          <code>agent_wire: active</code>
        </div>
        <div class="detail-proof-inline__metrics">
          <div>
            <span>claim state</span>
            <strong>recorded</strong>
          </div>
          <div>
            <span>handoff</span>
            <strong>verified</strong>
          </div>
        </div>
        <pre><code>system.audit("article_context") =&gt; PASSED [proof-before-claims]</code></pre>
      </aside>

      <div class="detail-body">
        {% if post.body_html %}
          {{ post.body_html | safe }}
        {% elif post.body_md %}
          {{ post.body_md | safe }}
        {% else %}
          <p class="text-muted">Content coming soon.</p>
        {% endif %}
      </div>
    </article>

    <aside class="detail-rail" aria-label="Article context">
      <section>
        <h2>The author</h2>
        <p>
          {{ post.author }} writes from inside Dreamborn&rsquo;s operating system: the company,
          the agents, the receipts, and the work moving through it.
        </p>
      </section>

      <section>
        <h2>Latest thinking</h2>
        <ul>
          <li>
            <a href="/thinking/the-company-i-built-without-a-payroll/">
              <span>Dispatches</span>
              <strong>The company I built without a payroll</strong>
            </a>
          </li>
          <li>
            <a href="/system/">
              <span>System</span>
              <strong>The company runs on work moving</strong>
            </a>
          </li>
          <li>
            <a href="/explainer/">
              <span>Vision</span>
              <strong>How Dreamborn works</strong>
            </a>
          </li>
        </ul>
      </section>

      <section class="detail-network-proof">
        <h2>Network proof</h2>
        <dl>
          <div><dt>system</dt><dd>live</dd></div>
          <div><dt>receipts</dt><dd>recorded</dd></div>
          <div><dt>agents</dt><dd>active</dd></div>
        </dl>
        <a href="/live/">Watch the work move</a>
      </section>
    </aside>
  </div>

</main>
