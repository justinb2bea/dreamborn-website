---
layout: base.njk
register: editorial
title: "Thinking — Dreamborn"
description: "Articles and thinking from Dreamborn on AI-native systems, agent workflows, and the future of work."
---

<main class="thinking-index">
  <div class="container thinking-index__grid">
    <aside class="thinking-rail" aria-label="Thinking filters and proof">
      <section class="thinking-rail__section">
        <h2>Categories</h2>
        <button class="thinking-topic"
                aria-pressed="true"
                data-topic-id=""
                onclick="handleTopicFilter(this, null)">
          <span>All topics</span>
          <em>{{ thinking.initial_posts.length | default(0) }}</em>
        </button>
        {% for topic in thinking.topics %}
        <button class="thinking-topic"
                aria-pressed="false"
                data-topic-id="{{ topic.id }}"
                onclick="handleTopicFilter(this, '{{ topic.id }}')">
          <span>{{ topic.label }}</span>
          <em>{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</em>
        </button>
        {% endfor %}
      </section>

      <section class="thinking-proof" aria-label="Operating proof">
        <div class="thinking-proof__title">
          <span></span>
          <h2>Operating Proof</h2>
        </div>
        <dl>
          <div>
            <dt>verification_rate</dt>
            <dd>live</dd>
          </div>
          <div>
            <dt>agent_contribution</dt>
            <dd>recorded</dd>
          </div>
          <div>
            <dt>last_system_sync</dt>
            <dd>continuous</dd>
          </div>
        </dl>
        <a href="/live/">Open live room</a>
      </section>
    </aside>

    <section class="thinking-main" aria-labelledby="thinkingTitle">
      <header class="thinking-header">
        <h1 id="thinkingTitle">Thinking</h1>
        <p>
          Long-form exploration into the intersection of human agency and machine intelligence.
          Every argument is grounded in the operating system we are building in public.
        </p>
      </header>

      <div class="thinking-list" id="postGrid" aria-live="polite" aria-atomic="false">
        {% for post in thinking.initial_posts %}
        <article class="thinking-entry" aria-label="Post: {{ post.title }}">
          <div class="thinking-entry__meta">
            <span class="thinking-badge">Proof verified</span>
            <span class="thinking-category">{{ post.topic_label or 'Article' }}</span>
          </div>
          <a href="/thinking/{{ post.slug }}/" class="thinking-entry__title">
            {% if post.card_title_html %}
              {{ post.card_title_html | safe }}
            {% else %}
              {{ post.title }}
            {% endif %}
          </a>
          {% if post.excerpt %}
          <p class="thinking-entry__excerpt">{{ post.excerpt }}</p>
          {% endif %}
          <div class="thinking-entry__footer">
            <div>
              <strong>{{ post.author }}</strong>
              <span>Dreamborn</span>
            </div>
            <time datetime="{{ post.published_at }}">{{ post.published_at | dateFormat }}</time>
          </div>
        </article>
        {% else %}
        <p class="text-muted thinking-empty">
          No posts published yet. Check back soon.
        </p>
        {% endfor %}
      </div>

      <div class="thinking-pagination" id="loadMoreWrap"
           {% if thinking.initial_posts.length < 12 %}style="display:none"{% endif %}>
        <button class="thinking-page-control" type="button" disabled>Previous</button>
        <span>Page 01</span>
        <button class="thinking-page-control thinking-page-control--next"
                id="loadMoreBtn"
                onclick="loadMorePosts()">
          Next
        </button>
      </div>
    </section>
  </div>

  <script id="thinkingData" type="application/json">
    {
      "initialCount": {{ thinking.initial_posts.length | json }},
      "topics": {{ thinking.topics | json }}
    }
  </script>
</main>

<script src="/js/thinking.js" defer></script>
