---
layout: base.njk
title: Dreamborn — AI-Native Systems
description: Dreamborn designs and deploys intelligent agent systems for forward-thinking businesses.
register: brand
---

<main class="home-page" id="main-content">

  {# ─── Hero ──────────────────────────────────────────────────────── #}
  <section class="home-hero" aria-label="Homepage hero">
    <div class="db-container">
      <h1 class="home-hero__heading">We Build AI-Native Systems</h1>
      <p class="home-hero__subhead hero-subhead">
        Agent workflows, CRM automation, and the infrastructure to run them. Dreamborn builds the systems that let your business run smarter.
      </p>
      <div class="home-hero__actions">
        <a href="/connect/" class="db-btn db-btn--primary home-hero__cta">Talk to Finn →</a>
        <a href="/work/" class="db-btn db-btn--ghost home-hero__secondary">See our work</a>
      </div>
    </div>
  </section>

  {# ─── Agent Status Bar ───────────────────────────────────────────── #}
  {% include "agent-status-bar.njk" %}

  {# ─── What we do ─────────────────────────────────────────────────── #}
  <section class="home-what" aria-label="What Dreamborn does">
    <div class="db-container">
      <h2 class="home-what__heading">What We Do</h2>
      <p class="home-what__body">
        <!-- CONTENT: Justin to supply copy -->
        Dreamborn designs and deploys AI-native systems: agent workflows that automate complex operations, CRM integrations that surface the right leads at the right moment, and the infrastructure to keep everything running at scale. We don't bolt AI onto existing processes — we rebuild them from the ground up for an agent-first world.
      </p>
      <a href="/work/" class="db-btn db-btn--ghost home-what__link">Explore our work →</a>
    </div>
  </section>

  {# ─── Featured Content Strip — shown only if 3+ published posts ── #}
  {% if featured_posts.length >= 3 %}
    <section class="home-featured" aria-label="Featured content">
      <div class="db-container">
        <h2 class="home-featured__heading">From Thinking</h2>
        <div class="home-featured__cards">
          {% for post in featured_posts %}
            <article class="featured-post-card">
              <a class="featured-post-card__link" href="/thinking/{{ post.slug }}/">
                <div class="featured-post-card__meta">
                  {% if post.published_at %}
                    <time class="featured-post-card__date" datetime="{{ post.published_at }}">
                      {{ post.published_at | formatDate }}
                    </time>
                  {% endif %}
                </div>
                <h3 class="featured-post-card__title">{{ post.title }}</h3>
                {% if post.excerpt %}
                  <p class="featured-post-card__excerpt">{{ post.excerpt }}</p>
                {% endif %}
              </a>
            </article>
          {% endfor %}
        </div>
        <div class="home-featured__cta">
          <a href="/thinking/" class="db-btn db-btn--ghost">Read more →</a>
        </div>
      </div>
    </section>
  {% endif %}

  {# ─── Finn invite band ───────────────────────────────────────────── #}
  <a href="/connect/" class="finn-band" aria-label="Open Finn chat on the Connect page">
    <div class="db-container finn-band__inner">
      <span class="finn-band__text">
        <span class="finn-band__label">Finn — AI agent</span>
        Ask me anything about Dreamborn →
      </span>
    </div>
  </a>

</main>

<script src="/js/finn-visitor.js" defer></script>
<script src="/js/agent-status.js" defer></script>

<style>
  /* ─── Hero ──────────────────────────────────────────────────────── */
  .home-hero {
    padding-block: var(--db-space-24) var(--db-space-20);
    border-bottom: 1px solid var(--db-border);
  }

  .home-hero__heading {
    font-size: clamp(var(--db-text-4xl), 8vw, var(--db-text-7xl));
    font-weight: 400; /* Bebas Neue — always renders bold by nature */
    color: var(--db-text);
    line-height: 1;
    letter-spacing: 0.03em;
    margin-bottom: var(--db-space-6);
    max-width: 840px;
  }

  .home-hero__subhead {
    font-family: var(--db-font-body);
    font-size: clamp(var(--db-text-base), 2vw, var(--db-text-xl));
    color: var(--db-text-muted);
    line-height: 1.7;
    max-width: 560px;
    margin-bottom: var(--db-space-10);
  }

  .home-hero__actions {
    display: flex;
    gap: var(--db-space-4);
    flex-wrap: wrap;
  }

  /* ─── What we do ────────────────────────────────────────────────── */
  .home-what {
    padding-block: var(--db-space-16);
    border-bottom: 1px solid var(--db-border);
  }

  .home-what__heading {
    font-size: clamp(var(--db-text-3xl), 5vw, var(--db-text-5xl));
    font-weight: 400;
    letter-spacing: 0.03em;
    color: var(--db-text);
    margin-bottom: var(--db-space-6);
  }

  .home-what__body {
    font-family: var(--db-font-body);
    font-size: var(--db-text-md);
    color: var(--db-text-muted);
    line-height: 1.8;
    max-width: 640px;
    margin-bottom: var(--db-space-8);
  }

  /* ─── Featured content ──────────────────────────────────────────── */
  .home-featured {
    padding-block: var(--db-space-16);
    border-bottom: 1px solid var(--db-border);
  }

  .home-featured__heading {
    font-size: clamp(var(--db-text-2xl), 4vw, var(--db-text-4xl));
    font-weight: 400;
    letter-spacing: 0.03em;
    color: var(--db-text);
    margin-bottom: var(--db-space-8);
  }

  .home-featured__cards {
    display: flex;
    gap: var(--db-space-5);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: var(--db-space-2);
    margin-bottom: var(--db-space-8);
  }

  .home-featured__cards::-webkit-scrollbar { display: none; }

  .featured-post-card {
    flex: 0 0 280px;
    width: 280px;
    background: var(--db-surface);
    border: 1px solid var(--db-border);
    border-radius: var(--db-radius-md);
    scroll-snap-align: start;
    transition: border-color var(--db-duration) var(--db-ease);
  }

  .featured-post-card:hover { border-color: var(--db-border-2); }

  .featured-post-card__link {
    display: flex;
    flex-direction: column;
    gap: var(--db-space-3);
    padding: var(--db-space-5);
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .featured-post-card__date {
    font-family: var(--db-font-ui);
    font-size: var(--db-text-xs);
    color: var(--db-text-faint);
  }

  .featured-post-card__title {
    font-family: var(--db-font-ui);
    font-size: var(--db-text-base);
    font-weight: 500;
    color: var(--db-text);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-post-card__excerpt {
    font-family: var(--db-font-ui);
    font-size: var(--db-text-sm);
    color: var(--db-text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .home-featured__cta {
    display: flex;
    justify-content: flex-start;
  }

  /* ─── Finn band ─────────────────────────────────────────────────── */
  .finn-band {
    display: block;
    background: var(--db-crimson-600);
    text-decoration: none;
    transition: background var(--db-duration) var(--db-ease);
  }

  .finn-band:hover {
    background: var(--db-crimson-700);
  }

  .finn-band__inner {
    padding-block: var(--db-space-6);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .finn-band__text {
    font-family: var(--db-font-ui);
    font-size: var(--db-text-base);
    font-weight: 500;
    color: var(--db-warm-white);
    display: flex;
    align-items: center;
    gap: var(--db-space-4);
    flex-wrap: wrap;
    justify-content: center;
    text-align: center;
  }

  .finn-band__label {
    font-size: var(--db-text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.15);
    border-radius: var(--db-radius-full);
    padding: 3px 10px;
  }
</style>
