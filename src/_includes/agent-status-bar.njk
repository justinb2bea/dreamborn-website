{#
  Agent Status Bar — shared partial used on /, /work, /system.
  Hardcoded roster: quinn, vikram, mindy, zara, finn, nora, courtney, atlas, claire.
  Cards are rendered with offline defaults; agent-status.js polls /api/agent-states
  every 60s and updates the DOM live.
#}
<section class="agent-status-bar" aria-label="{{ statusBarLabel or 'Live Agent Activity' }}">
  <div class="db-container db-container--wide">
    <div class="agent-status-bar__header">
      <span class="db-label db-label--accent">{{ statusBarLabel or 'Live Agent Activity' }}</span>
      <span class="db-live-badge" aria-label="Live polling active">
        <span class="db-live-badge__dot" aria-hidden="true"></span>
        Live
      </span>
    </div>
    <div class="agent-status-bar__cards" role="list">

      <div class="agent-card" data-agent="quinn" data-status="offline" role="listitem">
        <div class="agent-card__header">
          <span class="status-dot status-dot--offline" aria-hidden="true"></span>
          <span class="agent-card__name">Quinn</span>
          <span class="status-label status-label--offline">OFFLINE</span>
        </div>
        <p class="agent-action"></p>
        <time class="agent-time" datetime=""></time>
      </div>

      <div class="agent-card" data-agent="vikram" data-status="offline" role="listitem">
        <div class="agent-card__header">
          <span class="status-dot status-dot--offline" aria-hidden="true"></span>
          <span class="agent-card__name">Vikram</span>
          <span class="status-label status-label--offline">OFFLINE</span>
        </div>
        <p class="agent-action"></p>
        <time class="agent-time" datetime=""></time>
      </div>

      <div class="agent-card" data-agent="mindy" data-status="offline" role="listitem">
        <div class="agent-card__header">
          <span class="status-dot status-dot--offline" aria-hidden="true"></span>
          <span class="agent-card__name">Mindy</span>
          <span class="status-label status-label--offline">OFFLINE</span>
        </div>
        <p class="agent-action"></p>
        <time class="agent-time" datetime=""></time>
      </div>

      <div class="agent-card" data-agent="zara" data-status="offline" role="listitem">
        <div class="agent-card__header">
          <span class="status-dot status-dot--offline" aria-hidden="true"></span>
          <span class="agent-card__name">Zara</span>
          <span class="status-label status-label--offline">OFFLINE</span>
        </div>
        <p class="agent-action"></p>
        <time class="agent-time" datetime=""></time>
      </div>

      <div class="agent-card" data-agent="finn" data-status="offline" role="listitem">
        <div class="agent-card__header">
          <span class="status-dot status-dot--offline" aria-hidden="true"></span>
          <span class="agent-card__name">Finn</span>
          <span class="status-label status-label--offline">OFFLINE</span>
        </div>
        <p class="agent-action"></p>
        <time class="agent-time" datetime=""></time>
      </div>

      <div class="agent-card" data-agent="nora" data-status="offline" role="listitem">
        <div class="agent-card__header">
          <span class="status-dot status-dot--offline" aria-hidden="true"></span>
          <span class="agent-card__name">Nora</span>
          <span class="status-label status-label--offline">OFFLINE</span>
        </div>
        <p class="agent-action"></p>
        <time class="agent-time" datetime=""></time>
      </div>

      <div class="agent-card" data-agent="courtney" data-status="offline" role="listitem">
        <div class="agent-card__header">
          <span class="status-dot status-dot--offline" aria-hidden="true"></span>
          <span class="agent-card__name">Courtney</span>
          <span class="status-label status-label--offline">OFFLINE</span>
        </div>
        <p class="agent-action"></p>
        <time class="agent-time" datetime=""></time>
      </div>

      <div class="agent-card" data-agent="atlas" data-status="offline" role="listitem">
        <div class="agent-card__header">
          <span class="status-dot status-dot--offline" aria-hidden="true"></span>
          <span class="agent-card__name">Atlas</span>
          <span class="status-label status-label--offline">OFFLINE</span>
        </div>
        <p class="agent-action"></p>
        <time class="agent-time" datetime=""></time>
      </div>

      <div class="agent-card" data-agent="claire" data-status="offline" role="listitem">
        <div class="agent-card__header">
          <span class="status-dot status-dot--offline" aria-hidden="true"></span>
          <span class="agent-card__name">Claire</span>
          <span class="status-label status-label--offline">OFFLINE</span>
        </div>
        <p class="agent-action"></p>
        <time class="agent-time" datetime=""></time>
      </div>

    </div>
  </div>
</section>

<style>
  .agent-status-bar {
    padding-block: var(--db-space-10);
    border-top: 1px solid var(--db-border);
    border-bottom: 1px solid var(--db-border);
  }

  .agent-status-bar__header {
    display: flex;
    align-items: center;
    gap: var(--db-space-4);
    margin-bottom: var(--db-space-6);
  }

  .agent-status-bar__cards {
    display: flex;
    gap: var(--db-space-4);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--db-border) transparent;
    padding-bottom: var(--db-space-2);
  }

  .agent-card {
    flex: 0 0 220px;
    width: 220px;
    padding: var(--db-space-4);
    background: var(--db-surface);
    border: 1px solid var(--db-border);
    border-radius: var(--db-radius-sm);
    font-family: var(--db-font-ui);
    scroll-snap-align: start;
    transition: border-color var(--db-duration) var(--db-ease);
  }

  .agent-card:hover {
    border-color: var(--db-border-2);
  }

  .agent-card[data-status="active"] {
    border-color: rgba(141, 198, 63, 0.3);
  }

  .agent-card__header {
    display: flex;
    align-items: center;
    gap: var(--db-space-2);
    margin-bottom: var(--db-space-2);
  }

  .agent-card__name {
    font-size: var(--db-text-sm);
    font-weight: 500;
    color: var(--db-text);
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Status dots */
  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-dot--active  { background: var(--db-lime-500); animation: db-pulse 1.5s ease-in-out infinite; }
  .status-dot--idle    { background: var(--db-neutral-400); }
  .status-dot--offline { background: var(--db-neutral-700, #3D3530); }

  /* Status labels */
  .status-label {
    font-size: var(--db-text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    flex-shrink: 0;
  }

  .status-label--active  { color: var(--db-lime-500); }
  .status-label--idle    { color: var(--db-text-muted); }
  .status-label--offline { color: var(--db-text-faint); }

  /* Action text */
  .agent-action {
    font-size: var(--db-text-xs);
    color: var(--db-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-height: 1.2em;
    margin-bottom: var(--db-space-1);
    line-height: 1.4;
  }

  /* Time ago */
  .agent-time {
    display: block;
    font-size: var(--db-text-xs);
    color: var(--db-text-faint);
    font-family: var(--db-font-mono);
    line-height: 1.4;
  }
</style>
