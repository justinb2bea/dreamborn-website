  /* ── In use: article opener ──────────────────────────────── */
  .composition {
    padding: 80px 64px;
    background:
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='17' height='17'><line x1='0' y1='17' x2='17' y2='0' stroke='%238A7E6A' stroke-opacity='0.10' stroke-width='1'/></svg>"),
      var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
