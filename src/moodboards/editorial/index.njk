  .type-card__label span { color: var(--crimson); }

  .type-display {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 64px;
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: 14px;
  }
  .type-display em { font-style: italic; }

  .type-display-meta,
  .type-body-meta {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--stone);
  }

  .type-body {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink-soft);
    margin-bottom: 18px;
  }

  .type-mono {
    font-family: 'Fira Code', monospace;
    font-size: 13px;
    color: var(--ink-soft);
    padding: 16px 20px;
    background: var(--bg-deep);
    border-radius: var(--radius);
    border-left: 2px solid var(--stone);
    margin-bottom: 12px;
  }

  /* ── Components ──────────────────────────────────────────── */
  .components { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: start; }
  @media (max-width: 900px) { .components { grid-template-columns: 1fr; } }

  .comp-block {
    padding: 40px 44px;
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
  }

  .comp-block h3 {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 28px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 14px;
    letter-spacing: 0.02em;
    border-radius: var(--radius);
    border: 1px solid transparent;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .btn--primary { background: var(--ink); color: var(--bg); }
  .btn--primary:hover { background: var(--crimson); }
  .btn--secondary { background: transparent; color: var(--ink); border-color: var(--stone); }
  .btn--secondary:hover { border-color: var(--ink); }
  .btn--ghost {
    background: transparent; color: var(--ink-soft);
    padding: 12px 0;
    border-bottom: 1px solid var(--ink);
    border-radius: 0;
  }
  .btn--ghost:hover { color: var(--crimson); border-bottom-color: var(--crimson); }
  .btn-row { display: flex; flex-wrap: wrap; gap: 14px; }

  .input-row { display: flex; flex-direction: column; gap: 8px; margin-top: 24px; }
  .input-row label {
    font-family: 'Fira Code', monospace; font-size: 11px;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-faint);
  }
  .input-row input {
    padding: 12px 16px;
    font-family: 'Inter', sans-serif; font-size: 15px;
    color: var(--ink); background: var(--bg); border: 1px solid var(--stone);
    border-radius: var(--radius); outline: none;
