    color: var(--ink-soft);
  }

  .header .dek {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 26px;
    line-height: 1.45;
    color: var(--ink-soft);
    max-width: 680px;
    margin-bottom: 22px;
  }

  .header .keywords {
    font-family: 'Fira Code', monospace;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--stone);
  }

  .header .keywords span { color: var(--ink-soft); }

  /* ── Section frame ───────────────────────────────────────── */
  .section { margin-bottom: 88px; }

  .section-label {
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 36px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--ink);
  }

  .section-label h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: 32px;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .section-label small {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  /* ── Palette ─────────────────────────────────────────────── */
  .swatches { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; }
  @media (max-width: 900px) { .swatches { grid-template-columns: repeat(2, 1fr); } }

  .swatch {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--rule);
    background: var(--surface);
  }
  .swatch__chip { aspect-ratio: 1 / 1; }
  .swatch__meta { padding: 16px 18px; border-top: 1px solid var(--rule); }
  .swatch__name {
    font-family: 'Cormorant Garamond', serif; font-weight: 500;
    font-size: 18px; color: var(--ink); margin-bottom: 6px;
  }
  .swatch__role {
    font-family: 'Fira Code', monospace; font-size: 10px;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--ink-faint); margin-bottom: 8px;
  }
  .swatch__hex { font-family: 'Fira Code', monospace; font-size: 12px; color: var(--ink-soft); }

  /* ── Typography ──────────────────────────────────────────── */
  .type-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; }
  @media (max-width: 900px) { .type-grid { grid-template-columns: 1fr; } }

  .type-card {
    padding: 40px 44px;
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
  }

  .type-card__label {
    font-family: 'Fira Code', monospace;
