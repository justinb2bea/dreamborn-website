<title>EDITORIAL moodboard — DREAMBORN</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&family=Fira+Code:wght@400;500&display=swap');

  /* ── Editorial palette ───────────────────────────────────────
     The light register. Reads like a paper — warm cream, deep ink,
     fine rules. Quiet, considered. The same family DNA (Crimson,
     Lime, Stone) but proportions tilt toward type and breathing
     room over decoration.
  */
  :root {
    --bg:          #EDE3D0;  /* warm beige cream — darker than neutral-50 */
    --bg-deep:     #E2D7C0;  /* fold shadow — deeper beige */
    --surface:     #F5EDDD;  /* lifted card surface — warm */
    --ink:         #0F0B0A;  /* deep warm black */
    --ink-soft:    #3D3530;  /* secondary type */
    --ink-faint:   #6B5F54;  /* meta, caption */
    --stone:       #8A7E6A;
    --stone-soft:  #C8C0B8;
    --rule:        #D6CAB0;  /* hairline rules — warmer */
    --walnut:      #3D2D1F;  /* nav bar — borrowed from Brand register */
    --walnut-light:#5C4530;
    --cream-nav:   #F2E6D2;  /* nav text */
    --brass:       #B89868;
    --crimson:     #8C1A13;
    --lime:        #8DC63F;
    --radius:      4px;
    --radius-lg:   8px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    background:
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='17' height='17'><line x1='0' y1='17' x2='17' y2='0' stroke='%238A7E6A' stroke-opacity='0.10' stroke-width='1'/></svg>"),
      var(--bg);
    color: var(--ink);
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 300;
    font-size: 16px;
    line-height: 1.6;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Top nav — borrowed walnut from Brand register ───────── */
  .topnav {
    background: var(--walnut);
    border-bottom: 1px solid rgba(184, 152, 104, 0.30);
  }

  .topnav__inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 18px 56px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .topnav__logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .topnav__logo img {
    height: 40px;
    width: auto;
    display: block;
  }

  .topnav__items {
    list-style: none;
    display: flex;
    gap: 28px;
    margin-left: 24px;
  }

  .topnav__items a {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 13px;
    letter-spacing: 0.02em;
    color: rgba(242, 230, 210, 0.65);
    text-decoration: none;
    transition: color 0.2s;
  }

  .topnav__items a:hover,
  .topnav__items a.is-active {
    color: var(--cream-nav);
  }

  .topnav__items a.is-active {
    border-bottom: 1px solid var(--brass);
    padding-bottom: 4px;
  }

  .topnav__cta {
    margin-left: auto;
    padding: 8px 18px;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.02em;
    color: var(--cream-nav);
    background: transparent;
    border: 1px solid var(--brass);
    border-radius: var(--radius);
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .topnav__cta:hover {
    background: var(--brass);
    color: var(--walnut);
  }

  .page { max-width: 1180px; margin: 0 auto; padding: 64px 56px 120px; }

  /* ── Masthead ────────────────────────────────────────────── */
  .header { margin-bottom: 96px; }

  .crumb {
    display: inline-flex;
