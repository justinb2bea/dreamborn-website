  }

  .article-byline {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    margin-bottom: 40px;
  }

  .article-byline__mark {
    width: 42px; height: 42px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--bg);
    display: flex; align-items: center; justify-content: center;
