    line-height: 1.55;
    color: var(--cream-soft);
    max-width: 600px;
    margin-bottom: 40px;
  }

  .composition__cta {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 52px;
    flex-wrap: wrap;
  }

  .composition__proof {
    display: flex;
