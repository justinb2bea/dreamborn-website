    font-weight: 400;
    font-size: clamp(48px, 6vw, 82px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--cream);
    margin-bottom: 28px;
    max-width: 760px;
  }

  .composition__title em { font-style: italic; font-weight: 500; color: var(--sage-bright); }

  .composition__lede {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
