    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
  }

  .type-card__label {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--brass);
    margin-bottom: 24px;
