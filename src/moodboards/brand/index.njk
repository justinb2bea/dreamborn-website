  .type-card__label span { color: var(--sage-bright); }

  .type-display {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 64px;
    line-height: 0.98;
    letter-spacing: -0.025em;
    color: var(--cream);
    margin-bottom: 14px;
  }

  .type-display em { font-style: italic; font-weight: 500; color: var(--sage-bright); }

  .type-display-meta,
  .type-body-meta {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
