  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600;700&family=Fira+Code:wght@400;500&display=swap');

  /* ── Brand palette — v2 ──────────────────────────────────────
     Pulled from the heritage interior photos: walnut wood as base,
     warm cream as type, sage as the peaceful note, brass as the
     metallic, crimson as a wax-seal accent. Sits squarely between
     the dark Forge and the light Editorial — closer to a wood-
     paneled library at dusk than a paper page in the sun.
  */
  :root {
    --walnut:       #3D2D1F;  /* deep walnut, page base */
    --walnut-light: #5C4530;  /* warm honey-walnut, gradient top */
    --walnut-deep:  #2A1F15;  /* shadow-side walnut */
    --surface:      #4A3625;  /* lifted wood surface */
    --surface-2:    #5A4530;  /* even more lifted */
    --cream:        #F2E6D2;  /* warm parchment, primary type */
    --cream-soft:   #D8C8AA;  /* secondary type, brass-cream */
    --brass:        #B89868;  /* champagne brass — meta, accent */
    --brass-deep:   #8A7050;
    --sage:         #8A9275;  /* peaceful welcoming green */
    --sage-bright:  #A8B093;  /* hover sage */
    --sage-deep:    #6B7458;
    --stone:        #8A7E6A;  /* structural — family DNA */
    --rule:         rgba(184, 152, 104, 0.20);   /* brass at low opacity for hairlines */
    --rule-strong:  rgba(184, 152, 104, 0.40);
    --crimson:      #8C1A13;
    --crimson-bright: #C03535;
    --lime:         #8DC63F;
    --radius:       4px;
    --radius-lg:    8px;

    /* — nav uses Forge dark — */
    --nav-bg:       #0A0807;
    --nav-text:     #F2E6D2;
    --nav-text-soft: rgba(242, 230, 210, 0.55);
    --nav-rule:     rgba(184, 152, 104, 0.22);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    background:
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='17' height='17'><line x1='0' y1='17' x2='17' y2='0' stroke='%23B89868' stroke-opacity='0.10' stroke-width='1'/></svg>"),
      linear-gradient(135deg, var(--walnut-light) 0%, var(--walnut) 55%, var(--walnut-deep) 100%);
    background-attachment: fixed;
    color: var(--cream);
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 300;
    font-size: 16px;
    line-height: 1.6;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
