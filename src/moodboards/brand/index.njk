  }

  .composition__proof dd {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: 26px;
    color: var(--cream);
  }

  /* ── Footer ──────────────────────────────────────────────── */
  .footer {
    margin-top: 96px;
