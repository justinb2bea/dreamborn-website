---
layout: false
permalink: /moodboards/forge/
title: FORGE moodboard — DREAMBORN
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>FORGE moodboard — DREAMBORN</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&family=Fira+Code:wght@400;500&display=swap');

  /* ── Forge palette — v2 ──────────────────────────────────────
     Dark dev surface. Stone-to-black gradient stays. Components
     now OPAQUE — diagonal lines belong to the body, never bleed
     through panels. Bebas Neue replaces the serif: industrial,
     condensed, all-caps. Sparks of Lime. Hammer and chisel.
  */
  :root {
    --bg-light:       #3D3530;
    --bg-dark:        #0F0B0A;
    --surface:        #0A0807;   /* deeper than v1 — opaque panel */
    --surface-2:      #141010;   /* lifted card */
    --surface-3:      #1C1614;   /* hover / accent surface */
    --text:           #FAF8F5;
    --text-soft:      #C8C0B8;
    --text-faint:     #8A7E6A;
    --text-mute:      #6B5F54;
    --stone:          #8A7E6A;
    --rule:           rgba(138, 126, 106, 0.22);
    --rule-bright:    rgba(138, 126, 106, 0.40);
    --crimson:        #8C1A13;
    --crimson-bright: #C03535;
    --lime:           #8DC63F;
    --lime-dim:       #6A9A2C;
    --lime-glow:      rgba(141, 198, 63, 0.20);
    --amber:          #C9A876;   /* idle / pending state */
    --walnut:         #3D2D1F;   /* family bridge — from Brand */
    --walnut-soft:    #5C4530;
    --brass:          #B89868;   /* family bridge — from Brand */
    --brass-soft:     #8A7050;
    --radius:         0;

    /* — nav uses Editorial darker cream — */
    --nav-bg:         #EDE3D0;
    --nav-ink:        #0F0B0A;
    --nav-ink-soft:   #3D3530;
    --nav-rule:       #D6CAB0;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    background:
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='17' height='17'><line x1='0' y1='17' x2='17' y2='0' stroke='%238A7E6A' stroke-opacity='0.14' stroke-width='1'/></svg>"),
      linear-gradient(108deg, var(--bg-light) 0%, var(--bg-dark) 70%);
    background-attachment: fixed;
    color: var(--text);
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 300;
    font-size: 16px;
    line-height: 1.6;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Top nav — borrowed Editorial darker cream ───────────── */
  .topnav {
    background: var(--nav-bg);
    border-bottom: 1px solid var(--nav-rule);
  }

  .topnav__inner {
    max-width: 1700px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .topnav__logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .topnav__logo img {
    height: 40px;
    width: auto;
    display: block;
  }

  .topnav__items {
    list-style: none;
    display: flex;
    gap: 28px;
    margin-left: 24px;
  }

  .topnav__items a {
    font-family: 'Fira Code', monospace;
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--nav-ink-soft);
    text-decoration: none;
    transition: color 0.2s;
  }

  .topnav__items a:hover,
  .topnav__items a.is-active {
    color: var(--nav-ink);
  }

  .topnav__items a.is-active {
    border-bottom: 1px solid var(--lime-dim);
    padding-bottom: 4px;
    color: var(--lime-dim);
  }

  .topnav__cta {
    margin-left: auto;
    padding: 8px 18px;
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    font-size: 14px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--nav-bg);
    background: var(--lime-dim);
    border: 1px solid transparent;
    border-radius: 0;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .topnav__cta:hover {
    background: var(--nav-ink);
    color: var(--nav-bg);
  }

  .page { max-width: 1700px; margin: 0 auto; padding: 32px 32px 96px; }

  /* ── Header ──────────────────────────────────────────────── */
  .header { margin-bottom: 72px; }

  .crumb {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 24px;
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .crumb a { color: var(--text-faint); text-decoration: none; border-bottom: 1px solid var(--rule); padding-bottom: 1px; }
  .crumb a:hover { color: var(--lime); border-color: var(--lime); }
  .crumb span { color: var(--text-mute); }

  .status-bar {
    display: grid;
    grid-template-columns: auto repeat(4, 1fr) auto;
    gap: 0;
    margin-bottom: 36px;
    background: var(--surface);
    border: 1px solid var(--rule);
  }

  .status-bar > div {
    padding: 14px 22px;
    border-right: 1px solid var(--rule);
    font-family: 'Fira Code', monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .status-bar > div:last-child { border-right: 0; }
  .status-bar strong {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 0.06em;
    color: var(--text);
    font-weight: 400;
  }
  .status-bar .dot {
    width: 8px; height: 8px;
    background: var(--lime);
    box-shadow: 0 0 0 4px var(--lime-glow);
    animation: pulse 2s ease-in-out infinite;
  }
  .status-bar .live strong { color: var(--lime); }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 4px var(--lime-glow); }
    50%      { box-shadow: 0 0 0 6px rgba(141, 198, 63, 0.08); }
  }

  .header h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    font-size: clamp(120px, 18vw, 240px);
    line-height: 0.88;
    letter-spacing: 0.04em;
    color: var(--text);
    margin-bottom: 16px;
    text-transform: uppercase;
  }

  .header h1 em {
    font-style: normal;
    color: var(--lime);
  }

  .header .dek {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 20px;
    line-height: 1.5;
    color: var(--text-soft);
    max-width: 720px;
    margin-bottom: 20px;
  }

  .header .keywords {
    font-family: 'Fira Code', monospace;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--stone);
  }
  .header .keywords span { color: var(--text); }

  /* ── Section frame ───────────────────────────────────────── */
  .section { margin-bottom: 72px; }

  .section-label {
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 28px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--rule-bright);
  }

  .section-label h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    font-size: 38px;
    letter-spacing: 0.04em;
    color: var(--text);
    text-transform: uppercase;
  }

  .section-label small {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  /* ── Palette ─────────────────────────────────────────────── */
  .swatches { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; }
  @media (max-width: 900px) { .swatches { grid-template-columns: repeat(2, 1fr); } }

  .swatch {
    overflow: hidden;
    border: 1px solid var(--rule);
    background: var(--surface);
  }
  .swatch__chip { aspect-ratio: 1 / 1; }
  .swatch__meta { padding: 14px 18px; border-top: 1px solid var(--rule); }
  .swatch__name {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    font-size: 22px;
    letter-spacing: 0.04em;
    color: var(--text);
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .swatch__role {
    font-family: 'Fira Code', monospace; font-size: 10px;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text-faint); margin-bottom: 6px;
  }
  .swatch__hex { font-family: 'Fira Code', monospace; font-size: 12px; color: var(--text-soft); }

  /* ── Typography ──────────────────────────────────────────── */
  .type-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 900px) { .type-grid { grid-template-columns: 1fr; } }

  .type-card {
    padding: 32px 36px;
    background: var(--surface);
    border: 1px solid var(--rule);
  }

  .type-card__label {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 24px;
  }
  .type-card__label span { color: var(--lime); }

  .type-display {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    font-size: clamp(56px, 6vw, 88px);
    line-height: 0.9;
    letter-spacing: 0.04em;
    color: var(--text);
    margin-bottom: 14px;
    text-transform: uppercase;
  }
  .type-display em { font-style: normal; color: var(--lime); }

  .type-display-meta,
  .type-body-meta {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--stone);
  }

  .type-body {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 17px;
    line-height: 1.65;
    color: var(--text-soft);
    margin-bottom: 18px;
  }

  .type-mono {
    font-family: 'Fira Code', monospace;
    font-size: 13px;
    color: var(--lime);
    padding: 16px 20px;
    background: var(--bg-dark);
    border-left: 2px solid var(--lime);
    margin-bottom: 12px;
    white-space: pre;
    overflow-x: auto;
  }
  .type-mono .pass { color: var(--lime); }
  .type-mono .meta { color: var(--text-mute); }

  /* ── Components ──────────────────────────────────────────── */
  .components { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; align-items: start; }
  @media (max-width: 900px) { .components { grid-template-columns: 1fr; } }

  .comp-block {
    padding: 32px 36px;
    background: var(--surface);
    border: 1px solid var(--rule);
  }

  .comp-block h3 {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 24px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    font-size: 16px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: var(--radius);
    border: 1px solid transparent;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .btn--primary { background: var(--lime); color: var(--bg-dark); }
  .btn--primary:hover { background: var(--lime-dim); color: var(--text); }
  .btn--secondary { background: transparent; color: var(--text); border-color: var(--stone); }
  .btn--secondary:hover { border-color: var(--lime); color: var(--lime); }
  .btn--danger { background: var(--crimson); color: var(--text); }
  .btn--danger:hover { background: var(--crimson-bright); }
  .btn-row { display: flex; flex-wrap: wrap; gap: 10px; }

  .input-row { display: flex; flex-direction: column; gap: 8px; margin-top: 24px; }
  .input-row label {
    font-family: 'Fira Code', monospace; font-size: 11px;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-faint);
  }
  .input-row input {
    padding: 12px 16px;
    font-family: 'Fira Code', monospace; font-size: 13px;
    color: var(--text); background: var(--bg-dark); border: 1px solid var(--rule-bright);
    border-radius: var(--radius); outline: none;
  }
  .input-row input::placeholder { color: var(--text-mute); }
  .input-row input:focus { border-color: var(--lime); }

  .agent-card {
    padding: 22px;
    background: var(--surface-2);
    border: 1px solid var(--rule);
    margin-top: 24px;
  }
  .agent-card__top {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 14px;
    font-family: 'Fira Code', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .agent-card__id { color: var(--text-faint); }
  .agent-card__status {
    color: var(--lime);
    display: inline-flex; align-items: center; gap: 8px;
  }
  .agent-card__status::before {
    content: ""; width: 6px; height: 6px;
    background: var(--lime);
    box-shadow: 0 0 0 3px var(--lime-glow);
  }
  .agent-card__name {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400; font-size: 30px;
    letter-spacing: 0.04em;
    color: var(--text); margin-bottom: 4px;
    text-transform: uppercase;
  }
  .agent-card__role {
    font-family: 'Inter', sans-serif; font-weight: 300;
    font-size: 13px; color: var(--text-soft); margin-bottom: 16px;
  }
  .agent-card__metrics {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px;
    padding-top: 14px; border-top: 1px solid var(--rule);
  }
  .agent-card__metrics dt {
    font-family: 'Fira Code', monospace; font-size: 10px;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-faint);
    margin-bottom: 4px;
  }
  .agent-card__metrics dd {
    font-family: 'Bebas Neue', sans-serif; font-size: 20px;
    letter-spacing: 0.04em;
    color: var(--text);
  }

  /* ============================================================
     HUD — F-16 / operating room
     ============================================================ */
  .hud {
    background: var(--surface);
    border: 1px solid var(--rule-bright);
    padding: 0;
    overflow: hidden;
  }

  .hud__top-strip {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    border-bottom: 1px solid var(--rule);
  }
  @media (max-width: 900px) { .hud__top-strip { grid-template-columns: repeat(3, 1fr); } }

  .hud__top-strip > div {
    padding: 18px 22px;
    border-right: 1px solid var(--rule);
    font-family: 'Fira Code', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .hud__top-strip > div:last-child { border-right: 0; }
  .hud__top-strip strong {
    display: block;
    margin-top: 6px;
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    font-size: 28px;
    letter-spacing: 0.04em;
    color: var(--text);
  }
  .hud__top-strip .live strong { color: var(--lime); }
  .hud__top-strip .crit strong { color: var(--crimson-bright); }
  .hud__top-strip .amber strong { color: var(--amber); }

  .hud__main {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.1fr;
    border-bottom: 1px solid var(--rule);
  }
  @media (max-width: 1100px) { .hud__main { grid-template-columns: 1fr; } }

  .hud__panel {
    padding: 24px 26px;
    border-right: 1px solid var(--rule);
  }
  .hud__panel:last-child { border-right: 0; }
  @media (max-width: 1100px) {
    .hud__panel { border-right: 0; border-bottom: 1px solid var(--rule); }
    .hud__panel:last-child { border-bottom: 0; }
  }

  .hud__panel-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 18px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--rule);
  }

  .hud__panel-head h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    font-size: 20px;
    letter-spacing: 0.08em;
    color: var(--text);
    text-transform: uppercase;
  }

  .hud__panel-head small {
    font-family: 'Fira Code', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--text-faint);
  }
  .hud__panel-head small.live { color: var(--lime); }

  /* ──── Agent grid ──── */
  .agent-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }

  .agent-tile {
    padding: 14px 16px;
    background: var(--surface-2);
    border: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 4px;
    position: relative;
  }

  .agent-tile__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: 'Fira Code', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .agent-tile__name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 24px;
    letter-spacing: 0.05em;
    color: var(--text);
    text-transform: uppercase;
    margin: 2px 0;
  }

  .agent-tile__role {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    color: var(--text-soft);
    font-weight: 300;
    margin-bottom: 8px;
  }

  .agent-tile__bottom {
    display: flex;
    justify-content: space-between;
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    color: var(--text-soft);
    padding-top: 8px;
    border-top: 1px dashed var(--rule);
  }

  .agent-tile__bottom span:first-child { color: var(--text-faint); text-transform: uppercase; letter-spacing: 0.08em; font-size: 10px; }

  .agent-tile__dot {
    width: 6px; height: 6px;
    border-radius: 50%;
  }
  .agent-tile__dot--live  { background: var(--lime);     box-shadow: 0 0 0 3px var(--lime-glow); }
  .agent-tile__dot--idle  { background: var(--amber); }
  .agent-tile__dot--crit  { background: var(--crimson-bright); }

  /* ──── Radials ──── */
  .radials-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .radial-big {
    position: relative;
    width: 200px;
    height: 200px;
  }

  .radial-big__center {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .radial-big__value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 60px;
    letter-spacing: 0.04em;
    color: var(--lime);
    line-height: 1;
  }

  .radial-big__label {
    font-family: 'Fira Code', monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-top: 6px;
  }

  .radial-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    width: 100%;
  }

  .radial-small {
    text-align: center;
  }

  .radial-small svg { display: block; margin: 0 auto 8px; }

  .radial-small__value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 0.04em;
    color: var(--text);
    line-height: 1;
  }
  .radial-small--live .radial-small__value { color: var(--lime); }
  .radial-small--idle .radial-small__value { color: var(--amber); }
  .radial-small--crit .radial-small__value { color: var(--crimson-bright); }

  .radial-small__label {
    font-family: 'Fira Code', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-top: 3px;
  }

  /* ──── Live feed ──── */
  .feed {
    font-family: 'Fira Code', monospace;
    font-size: 12px;
    line-height: 1.7;
  }

  .feed-line {
    display: grid;
    grid-template-columns: 84px 1fr auto;
    gap: 12px;
    padding: 6px 0;
    color: var(--text-soft);
    border-bottom: 1px dashed var(--rule);
  }
  .feed-line:last-child { border-bottom: 0; }
  .feed-line .t  { color: var(--text-faint); }
  .feed-line .m strong { color: var(--text); }
  .feed-line .tag {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    align-self: center;
  }
  .feed-line.live .tag { color: var(--lime); }
  .feed-line.done .tag { color: var(--text-faint); }
  .feed-line.crit .tag { color: var(--crimson-bright); }
  .feed-line.crit .m   { color: var(--crimson-bright); }

  /* ──── Bottom row — now 3 columns ──── */
  .hud__bottom {
    display: grid;
    grid-template-columns: 1.2fr 0.85fr 0.95fr;
  }
  @media (max-width: 1100px) { .hud__bottom { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 720px)  { .hud__bottom { grid-template-columns: 1fr; } }

  .hud__panel--bars { padding-bottom: 28px; }

  .bars-chart {
    display: flex;
    align-items: flex-end;
    gap: 4px;
    height: 140px;
    margin-bottom: 12px;
    padding-top: 18px;
    border-bottom: 1px solid var(--rule);
  }

  .bar {
    flex: 1;
    background: var(--lime);
    min-height: 4px;
    position: relative;
  }
  .bar--peak  { background: var(--lime); box-shadow: 0 0 8px rgba(141, 198, 63, 0.4); }
  .bar--dim   { background: var(--lime-dim); }
  .bar--crit  { background: var(--crimson); }
  .bar--brass { background: var(--brass); }  /* family bridge — 5-10% appearance */
  .bar--walnut{ background: var(--walnut-soft); }

  .bars-axis {
    display: flex;
    justify-content: space-between;
    font-family: 'Fira Code', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    color: var(--text-mute);
  }

  /* ──── Sequence panel ──── */
  .seq-list { font-family: 'Fira Code', monospace; font-size: 11px; }

  .seq-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 12px;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px dashed var(--rule);
  }
  .seq-item:last-child { border-bottom: 0; }

  .seq-icon {
    width: 18px; height: 18px;
    border: 1px solid var(--stone);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text);
    font-size: 11px;
  }
  .seq-icon--done { background: var(--surface-2); color: var(--lime); border-color: var(--lime); }
  .seq-icon--live { background: var(--lime); color: var(--bg-dark); border-color: var(--lime); }
  .seq-icon--crit { background: var(--crimson); color: var(--text); border-color: var(--crimson); }

  .seq-body strong { color: var(--text); font-weight: 500; font-family: 'Inter', sans-serif; font-size: 12px; }
  .seq-body span   { color: var(--text-soft); font-size: 11px; }

  .seq-time { color: var(--text-faint); font-size: 10px; letter-spacing: 0.1em; }

  .seq-icon--brass { background: var(--brass); color: var(--bg-dark); border-color: var(--brass); }

  /* ──── Sales pipeline rings — new infographic ──── */
  .sales-rings {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 22px;
    align-items: center;
    padding-top: 4px;
  }

  @media (max-width: 600px) {
    .sales-rings { grid-template-columns: 1fr; gap: 14px; }
    .sales-rings__chart svg { margin: 0 auto; }
  }

  .sales-rings__chart {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .sales-rings__legend {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .leg {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 6px 0;
    border-bottom: 1px dashed var(--rule);
  }
  .leg:last-child { border-bottom: 0; }

  .leg__dot {
    width: 10px;
    height: 10px;
    flex-shrink: 0;
  }

  .leg__dot--leads     { background: var(--stone); }
  .leg__dot--qualified { background: var(--brass); }
  .leg__dot--inpipe    { background: var(--amber); }
  .leg__dot--won       { background: var(--lime); box-shadow: 0 0 0 3px var(--lime-glow); }

  .leg__body { flex: 1; }

  .leg__name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 16px;
    letter-spacing: 0.08em;
    color: var(--text);
    text-transform: uppercase;
    line-height: 1;
    margin-bottom: 4px;
  }

  .leg__meta {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    color: var(--text-faint);
    letter-spacing: 0.04em;
  }

  .leg__meta strong {
    color: var(--text-soft);
    font-weight: 500;
  }

  /* ── Footer ──────────────────────────────────────────────── */
  .footer {
    margin-top: 80px;
    padding-top: 24px;
    border-top: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--text-faint);
  }

  .footer a { color: var(--text-faint); text-decoration: none; border-bottom: 1px solid var(--rule); }
  .footer a:hover { color: var(--lime); border-color: var(--lime); }
</style>
</head>
