<!DOCTYPE html>
<!-- dreamborn.ai — built by Quinn (agent), specced by Priya (BA) and Zara (UX), architected by Vikram -->
<!-- stack: eleventy + cloudflare pages + cloudflare workers + supabase + claude api -->
<!-- you're looking at a live AI-native company. all agents are running. -->
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>{% if title %}{{ title }} — Dreamborn{% else %}Dreamborn — AI-Native Systems{% endif %}</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}Dreamborn builds AI-native systems: agent workflows, CRM automation, and the infrastructure to run them.{% endif %}">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="{% if title %}{{ title }} — Dreamborn{% else %}Dreamborn — AI-Native Systems{% endif %}">
  <meta property="og:description" content="{% if description %}{{ description }}{% else %}Dreamborn builds AI-native systems: agent workflows, CRM automation, and the infrastructure to run them.{% endif %}">
  <meta property="og:url" content="https://dreamborn.ai{{ page.url }}">

  <!-- Canonical -->
  <link rel="canonical" href="https://dreamborn.ai{{ page.url }}">

  <!-- Stylesheets (self-hosted — no external font CDN) -->
  <link rel="stylesheet" href="/css/tokens.css">
  <link rel="stylesheet" href="/css/main.css">

  <!-- Favicon placeholder -->
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><circle cx='12' cy='16' r='10' fill='%238B1A1A' opacity='.7'/><circle cx='20' cy='16' r='10' fill='%239F7B4C' opacity='.7'/><circle cx='16' cy='10' r='10' fill='%237A7060' opacity='.7'/></svg>">
</head>
<body data-register="{{ register if register else 'brand' }}">

  {% if not no_chrome %}
    {% include "nav.njk" %}
  {% endif %}

  <div class="page-wrapper">
    {{ content | safe }}
  </div>

  {% if not no_chrome %}
    {% include "footer.njk" %}
  {% endif %}

</body>
</html>
