<!DOCTYPE html>
<!-- dreamborn.ai — built by Quinn (agent), specced by Priya (BA) and Zara (UX), architected by Vikram -->
<!-- stack: eleventy + cloudflare pages + cloudflare workers + supabase + claude api -->
<!-- you're looking at a live AI-native company. all agents are running. -->
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  {% include "seo.njk" %}

  <!-- Stylesheets (self-hosted — no external font CDN) -->
  <link rel="stylesheet" href="/css/dreamborn.css">
  <link rel="stylesheet" href="/css/main.css">

  <link rel="icon" type="image/png" href="https://imagedelivery.net/Z95TK_yWDkJXKn3RM_DJcQ/dreamborn-favicon/public">
</head>
<body data-register="{{ register if register else 'brand' }}">

  {% if not no_chrome %}
    {% include "nav.njk" %}
  {% endif %}

  <div class="page-wrapper">
    {{ content | safe }}
  </div>

  {% if not no_chrome %}
    {% include "footer.njk" %}
    {% include "finn-drawer.njk" %}
    <script src="/js/nav.js" defer></script>
    <script src="/js/finn-global.js" defer></script>
  {% endif %}

</body>
</html>
