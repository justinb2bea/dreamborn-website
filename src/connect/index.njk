---
layout: base.njk
register: forge
title: "Ask Finn"
description: "Enter Dreamborn's AI strategy room. Ask Finn, pressure-test your operating model, or book a call with Justin."
---

<main class="connect-room">
  <section class="connect-hero" aria-labelledby="connectHeroTitle">
    <div class="connect-hero__copy">
      <p class="ops-kicker">Connect / AI strategy room</p>
      <h1 id="connectHeroTitle">What&rsquo;s your AI strategy? Bring it here.</h1>
      <p>
        Dreamborn is an AI-native company. Finn can show you how it works, pressure-test what you&rsquo;re building, and route you to the right next conversation.
      </p>
    </div>

    <div class="connect-live-strip" aria-label="Dreamborn operating status">
      <span>Finn online</span>
      <span>Bezel live</span>
      <span>24 agents</span>
      <span>5 active now</span>
    </div>
  </section>

  <section class="connect-capabilities" aria-label="What Finn can do">
    <p class="ops-panel-label">Finn can</p>
    <div class="connect-capability-list">
      <span>Explain Bezel</span>
      <span>Pressure-test your AI strategy</span>
      <span>Map agent coverage for your company</span>
      <span>Show live operating proof</span>
      <span>Route you to Justin</span>
    </div>
  </section>

  <section class="connect-stage" aria-label="Ask Finn">
    <div class="connect-chat-shell">
      <div class="connect-chat-topline">
        <div>
          <p class="ops-panel-label">Front-door operator</p>
          <h2>Start with Finn.</h2>
        </div>
        <span>live</span>
      </div>

      <div class="finn-chat" role="region" aria-label="Chat with Finn, Dreamborn's AI agent">
        <div class="finn-chat__header">
          <div class="finn-chat__avatar" aria-hidden="true">F</div>
          <div>
            <p class="finn-chat__name">Finn</p>
            <p class="finn-chat__subtitle">Dreamborn AI Agent</p>
          </div>
        </div>

        <div class="finn-chat__messages" id="finnMessages" role="log" aria-live="polite" aria-label="Conversation">
          <div class="message-bubble message-bubble--finn" role="article" aria-label="Finn: greeting">
            I&rsquo;m Finn. I can show you how Dreamborn runs, pressure-test your AI strategy, or help you decide whether this operating model fits your company.<br><br>
            What are you trying to build?
          </div>

          <div class="finn-typing" id="finnTyping" aria-hidden="true" aria-label="Finn is typing">
            <span class="finn-typing-dot"></span>
            <span class="finn-typing-dot"></span>
            <span class="finn-typing-dot"></span>
          </div>
        </div>

        <div class="suggested-prompts" id="finnPrompts" role="group" aria-label="Suggested messages">
          <button class="prompt-pill" data-prompt="Pressure-test my AI strategy">Pressure-test my AI strategy</button>
          <button class="prompt-pill" data-prompt="Show me how Dreamborn runs">Show me how Dreamborn runs</button>
          <button class="prompt-pill" data-prompt="What would Bezel do for my company?">What would Bezel do for my company?</button>
          <button class="prompt-pill" data-prompt="How would you rebuild CRM AI first?">How would you rebuild CRM AI first?</button>
          <button class="prompt-pill" data-prompt="I'm building agent workflows">I&rsquo;m building agent workflows</button>
          <button class="prompt-pill" data-prompt="I want to talk to Justin">I want to talk to Justin</button>
        </div>

        <p class="finn-error" id="finnError" role="alert">
          Finn is temporarily unavailable. <a href="#booking">Book directly &rarr;</a>
        </p>

        <div class="finn-chat__input-area">
          <textarea class="finn-chat__input"
                    id="finnInput"
                    placeholder="Tell Finn what you&rsquo;re trying to build..."
                    aria-label="Message Finn"
                    rows="1"
                    maxlength="2000"
                    onkeydown="handleFinnKeydown(event)"></textarea>
          <button class="finn-chat__send"
                  id="finnSendBtn"
                  onclick="sendFinnMessage()"
                  aria-label="Send message">
            Send
          </button>
        </div>
      </div>
    </div>

    <aside class="connect-rail" aria-label="Book with Justin">
      <section class="connect-rail-panel connect-rail-panel--booking" id="booking">
        <div class="connect-booking-head">
          <p class="ops-panel-label">Executive handoff</p>
          <span>live route</span>
        </div>
        <h2>Book with Justin.</h2>
        <p>If the conversation is real, take it live. Walk through the operating model, your use case, and whether Dreamborn should be involved.</p>

        <details class="connect-booking">
          <summary>
            <span>Open Justin&rsquo;s calendar</span>
            <small>Intro call / live walkthrough / fit check</small>
          </summary>
          <div class="connect-cal-frame">
            <cal-inline data-cal-link="justin-king"></cal-inline>
          </div>
        </details>
      </section>
    </aside>
  </section>
</main>

<script>
  (function (C, A, L) {
    let p = function (a, ar) { a.q.push(ar); };
    let d = C.document;
    C.Cal = C.Cal || function () {
      let cal = C.Cal;
      let ar = arguments;
      if (!cal.loaded) {
        cal.ns = {};
        cal.q = cal.q || [];
        d.head.appendChild(d.createElement("script")).src = A;
        cal.loaded = true;
      }
      if (ar[0] === L) {
        const api = function () { p(api, arguments); };
        const namespace = ar[1];
        api.q = api.q || [];
        if (typeof namespace === "string") {
          cal.ns[namespace] = cal.ns[namespace] || api;
          p(cal.ns[namespace], ar);
          p(cal, ["initNamespace", namespace]);
        } else {
          p(cal, ar);
        }
        return;
      }
      p(cal, ar);
    };
  })(window, "https://app.cal.com/embed/embed.js", "init");
  Cal("init", { origin: "https://cal.com" });
  Cal("preload", { calLink: "justin-king" });
  Cal("ui", {
    theme: "dark",
    hideEventTypeDetails: false,
    cssVarsPerTheme: {
      dark: {
        "cal-brand": "#8B1A1A",
        "cal-brand-emphasis": "#A52A24",
        "cal-brand-text": "#FFFFFF",
        "cal-brand-subtle": "#D7B16E",
        "cal-bg": "#100D0C",
        "cal-bg-emphasis": "#18110F",
        "cal-bg-subtle": "#171110",
        "cal-bg-muted": "#0A0807",
        "cal-bg-inverted": "#F0EDE9",
        "cal-text": "#C8C0B8",
        "cal-text-emphasis": "#F0EDE9",
        "cal-text-subtle": "#8A7E6A",
        "cal-border": "#2A1F1C",
        "cal-border-emphasis": "#8B1A1A",
        "cal-border-subtle": "#3B2A25",
        "cal-border-muted": "#1F1714",
        "cal-border-booker": "#2A1F1C",
        "cal-border-booker-width": "1px",
        "radius": "0.25rem",
        "radius-sm": "0.125rem",
        "radius-md": "0.25rem",
        "radius-lg": "0.5rem",
        "spacing": "0.25rem"
      }
    }
  });
  Cal("inline", {
    elementOrSelector: "cal-inline",
    calLink: "justin-king",
    config: {
      layout: "month_view",
      theme: "dark",
      hideEventTypeDetails: false
    }
  });
</script>

<script src="/js/finn-chat.js" defer></script>
