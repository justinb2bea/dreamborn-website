  }

  .finn-error__book:hover {
    text-decoration: underline;
  }

  /* ─── Screen reader only utility ────────────────────────────────── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* ─── Cal.com column ────────────────────────────────────────────── */
  .connect-cal__heading {
    font-size: clamp(var(--db-text-2xl), 4vw, var(--db-text-4xl));
    font-weight: 400;
    letter-spacing: 0.03em;
    color: var(--db-text);
    margin-bottom: var(--db-space-2);
  }

  .connect-cal__subhead {
    font-family: var(--db-font-ui);
    font-size: var(--db-text-sm);
    color: var(--db-text-muted);
    margin-bottom: var(--db-space-6);
  }

  .connect-cal__embed-wrapper {
    border: 1px solid var(--db-border);
    border-radius: var(--db-radius-lg);
    overflow: hidden;
    background: var(--db-surface);
  }

  @media (max-width: 860px) {
    /* On mobile, wrap Cal.com in an accordion */
    .connect-cal__embed-wrapper {
      /* The cal-inline embed is always rendered; mobile layout stacks naturally */
    }
  }
</style>
