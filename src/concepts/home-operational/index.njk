  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap');

  /* ---------- PAGE BACKGROUND ----------
     45° diagonal grid (now visible) on a directional gradient that
     drops from lighter warm gray (top-left) into near-black (bottom-
     right). The gradient gives depth; the grid gives the crisp tech
     feel. Lines show clearly against the lighter top-left and fade
     into the dark bottom-right — that fade is the design.
  */
  .concept-page {
    background-color: #0A0807;
    background-image:
      /* Inline SVG tile — 17×17 with a single diagonal stroke from
         bottom-left to top-right. Tiles seamlessly. ~12px perpendicular
         spacing between lines (17 / √2 ≈ 12). SVG renders hairlines
         consistently across browsers and zoom levels — no dropouts. */
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='17' height='17'><line x1='0' y1='17' x2='17' y2='0' stroke='%23C8C0B8' stroke-opacity='0.07' stroke-width='1'/></svg>"),
      /* HORIZONTAL gradient — lighter gray on left, near-black on right.
         Every section, all the way down the page, sees the same band. */
      linear-gradient(
        90deg,
        #2C2620 0%,
        #1F1813 28%,
        #14100D 60%,
        #08060A 100%
